# Which LLM provider to use. Options: "claude" (default), "gemini".
YT_SUMMARIZER_PROVIDER=claude

# Optional model override. Falls back to the provider's default if unset:
#   claude → claude-opus-4-7
#   gemini → gemini-3-flash-preview
# YT_SUMMARIZER_MODEL=

# --- Provider keys (set the one matching YT_SUMMARIZER_PROVIDER) -----------
# Anthropic Claude — get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini — get a free key at https://aistudio.google.com/apikey
# GOOGLE_API_KEY=...
